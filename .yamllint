---
# yamllint configuration for RAG Processor
extends: default

# Ignore generated, vendored, and third-party config files
ignore: |
  .venv/
  node_modules/
  build/
  dist/
  docker-compose.prod.yml

rules:
  # GitHub Actions uses `on:` as a top-level key. YAML 1.1 parses unquoted
  # `on` as boolean True; the truthy rule warns about it. Allow it explicitly.
  truthy:
    allowed-values: ["true", "false", "on", "off"]
    check-keys: true

  line-length:
    max: 150
    level: warning
    allow-non-breakable-inline-mappings: true

  # Disallow duplicate keys (forbid-duplicated-merge-keys removed - not supported in all yamllint versions)
  key-duplicates: enable

  # Allow flow sequences with no spaces (GitHub Actions style)
  brackets:
    max-spaces-inside: 0
    min-spaces-inside: 0

  # More lenient indentation for readability
  indentation:
    spaces: 2
    indent-sequences: true

  # Allow comments without space after #
  comments:
    require-starting-space: true
    min-spaces-from-content: 1

  # Allow longer lines in comments
  comments-indentation: {}

  # Disable document start requirement (---)
  document-start: disable
